<!-- 欢迎页内容 -->
<h1 id="cover-title">我的知识库</h1>
> 记录思考 · 沉淀技术 · 安静写字

[开始阅读](README.md)
[GitHub](https://github.com/你的用户名)

<!-- 滚动提示（点击开始阅读仍有效） -->
<div class="scroll-hint">点击按钮或向下滚动</div>

<!-- 粒子画布 -->
<canvas id="particles-canvas" style="position:fixed; top:0; left:0; z-index:1;"></canvas>

<script>
(function() {
    // 标题逐字包裹（自动将h1文字拆成<span>）
    var titleEl = document.getElementById('cover-title');
    if (titleEl) {
        var text = titleEl.textContent.trim();
        var html = '';
        for (var i = 0; i < text.length; i++) {
            var char = text[i] === ' ' ? '&nbsp;' : text[i];
            html += '<span style="animation-delay:' + (i * 0.05) + 's">' + char + '</span>';
        }
        titleEl.innerHTML = html;
    }

    // 粒子动画（优化版：随机变色，偶尔泛金）
    var canvas = document.getElementById('particles-canvas');
    var ctx = canvas.getContext('2d');
    var w, h;
    var particles = [];

    function resize() {
        w = canvas.width = window.innerWidth;
        h = canvas.height = window.innerHeight;
    }
    resize();
    window.addEventListener('resize', resize);

    function Particle() {
        this.x = Math.random() * w;
        this.y = Math.random() * h;
        this.vx = (Math.random() - 0.5) * 0.8;
        this.vy = (Math.random() - 0.5) * 0.8;
        this.radius = Math.random() * 2.5 + 0.8;
        this.opacity = Math.random() * 0.6 + 0.2;
        // 随机颜色倾向：大多数白色，偶尔金色
        this.color = Math.random() < 0.15 ? '201,169,98' : '255,255,255'; // 金 or 白
    }

    Particle.prototype.update = function() {
        this.x += this.vx;
        this.y += this.vy;
        if (this.x < 0 || this.x > w) this.vx *= -1;
        if (this.y < 0 || this.y > h) this.vy *= -1;
    };

    Particle.prototype.draw = function() {
        ctx.beginPath();
        ctx.arc(this.x, this.y, this.radius, 0, Math.PI * 2);
        ctx.fillStyle = 'rgba(' + this.color + ', ' + this.opacity + ')';
        ctx.fill();
    };

    var particleCount = 100;
    for (var i = 0; i < particleCount; i++) {
        particles.push(new Particle());
    }

    function animate() {
        ctx.clearRect(0, 0, w, h);
        ctx.fillStyle = '#1a1a1a';
        ctx.fillRect(0, 0, w, h);

        for (var i = 0; i < particles.length; i++) {
            particles[i].update();
            particles[i].draw();
        }

        // 连线优化：只连接近的、相同色调的粒子
        for (var i = 0; i < particles.length; i++) {
            for (var j = i + 1; j < particles.length; j++) {
                var dx = particles[i].x - particles[j].x;
                var dy = particles[i].y - particles[j].y;
                var dist = Math.sqrt(dx * dx + dy * dy);
                if (dist < 100) {
                    // 如果是金色粒子，连线更亮
                    var alpha = (0.15 * (1 - dist / 100));
                    var color = particles[i].color === '201,169,98' ? '201,169,98' : '255,255,255';
                    ctx.beginPath();
                    ctx.moveTo(particles[i].x, particles[i].y);
                    ctx.lineTo(particles[j].x, particles[j].y);
                    ctx.strokeStyle = 'rgba(' + color + ', ' + alpha + ')';
                    ctx.lineWidth = 0.5;
                    ctx.stroke();
                }
            }
        }
        requestAnimationFrame(animate);
    }
    animate();
})();
</script>